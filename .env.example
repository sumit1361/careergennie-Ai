NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/careergenie

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Python interpreter used by child_process.spawn (use "python3" on most systems)
PYTHON_BIN=python3

# Client origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173
